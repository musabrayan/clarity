# ============================================================================
# FLASK CONFIGURATION
# ============================================================================
SECRET_KEY=your-random-jwt-secret-key
FLASK_ENV=development
PORT=5000

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
# Get from MongoDB Atlas (free M0 cluster): https://cloud.mongodb.com
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=clarity

# ============================================================================
# TWILIO CONFIGURATION
# Get from https://www.twilio.com/console
# ============================================================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_API_KEY=your-twilio-api-key
TWILIO_API_SECRET=your-twilio-api-secret
TWIML_APP_SID=your-twiml-app-sid

# ============================================================================
# AI CONFIGURATION
# Get from https://console.groq.com/keys (free tier)
# ============================================================================
GROQ_API_KEY=your-groq-api-key

# ============================================================================
# URLS
# ============================================================================
# Your deployed backend URL (e.g. https://your-app.onrender.com)
BASE_URL=http://localhost:5000

# Your deployed frontend URL (e.g. https://your-app.vercel.app)
# Comma-separated for multiple origins
FRONTEND_URL=http://localhost:5173

# ============================================================================
# LOGGING CONFIGURATION
# ============================================================================
LOG_LEVEL=INFO
